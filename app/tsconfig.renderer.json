{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM"],
		"jsx": "react-jsx",
		"rootDir": "src/renderer",
		"outDir": "dist/renderer",
		"strict": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"noEmitOnError": true
	},
	"include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"]
}
