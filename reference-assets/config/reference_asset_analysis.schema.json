{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reference Asset Analysis",
  "type": "object",
  "required": ["schemaVersion", "asset", "summary", "frames"],
  "properties": {
    "schemaVersion": {
      "const": "reference-asset-analysis/v1"
    },
    "asset": {
      "type": "object",
      "required": ["assetId", "collection", "kind", "sourcePath", "originalPath", "sha256", "sizeBytes"],
      "properties": {
        "assetId": { "type": "string", "minLength": 1 },
        "collection": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["image", "video"] },
        "sourcePath": { "type": "string", "minLength": 1 },
        "originalPath": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "width": { "type": ["integer", "null"], "minimum": 1 },
        "height": { "type": ["integer", "null"], "minimum": 1 },
        "duration": { "type": ["number", "null"], "minimum": 0 },
        "fps": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": ["frameCount", "personPresent", "subtitlePresent", "titlePresent", "logoPresent", "annotationPresent"],
      "additionalProperties": true
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "frameId",
          "timeSeconds",
          "width",
          "height",
          "people",
          "faces",
          "textOverlays",
          "logos",
          "annotations",
          "composition",
          "visualStyle"
        ],
        "properties": {
          "frameId": { "type": "string", "minLength": 1 },
          "timeSeconds": { "type": "number", "minimum": 0 },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "samplePath": { "type": ["string", "null"] },
          "debugOverlayPath": { "type": ["string", "null"] },
          "people": { "type": "array" },
          "faces": { "type": "array" },
          "textOverlays": { "type": "array" },
          "logos": { "type": "array" },
          "annotations": { "type": "array" },
          "composition": { "type": "object" },
          "visualStyle": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
